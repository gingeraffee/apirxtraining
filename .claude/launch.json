{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "node",
      "runtimeArgs": ["node_modules/next/dist/bin/next", "dev"],
      "port": 3000,
      "cwd": "frontend",
      "env": {
        "NEXT_PUBLIC_API_BASE_URL": "http://127.0.0.1:8001/api/v1"
      }
    },
    {
      "name": "backend",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uvicorn", "app.main:app", "--reload", "--port", "8001"],
      "port": 8001,
      "cwd": "backend"
    }
  ]
}
